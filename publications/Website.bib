	journal = {JAMA Network Open},
	author = {Engels, Geraldine and Forster, Johannes and Streng, Andrea and Rücker, Viktoria and Rudolph, Paul and Pietsch, Franziska and Wallstabe, Julia and Wallstabe, Lars and Krauthausen, Maike and Schmidt, Julia and Ludwig, Timo and Bauer, Carsten and Gierszewski, David and Bendig, Jesper and Timme, Sandra and Jans, Thomas and Weißbrich, Benedikt and Romanos, Marcel and Dölken, Lars and Heuschmann, Peter and Härtel, Christoph and Gágyor, Ildikó and Figge, Marc Thilo and Liese, Johannes and Kurzai, Oliver and {Wue-KiTa-CoV 2.0-Study Group} and Amman, Annsophie and Besenfelder, Anastasia and Bode, Leonie and Enders, Inga and Frank, Thiemo and Frei, Kathrin and Habersack, Greta and Hamway, Viktoria and Höferth, Theresa and Lâm, Thiên-Tri and Mündlein, Sabrina and Rauch, Konstanze and Schoen, Christoph and Spannagel, Timo and Rothbauer, Fabian and Abert, Marianna and Bley, Julia and Durnev, Tatjana and Glatzle, Carolin and Hardung, Antonia and Karch, Katharina and Kollert, Sebastian and Mastorakis, Tanja and Schregelmann, Lena and Sokalski, Victoria and Tanzberger, Eva-Lotta and Thieme, Anne and Yilmaz, Denise and Zimmerling, Stefan and Nehm, Pauline and Siegl, Max and Wehner, Brigitte and Knies, Kerstin and Richter, Rebecca and Düber, Hülya and Kraft, Monika and Schuchardt, Christian and Finkenberg, Barbara and Löw, Johann},
