@article{dolken_systematic_2010,
	title = {Systematic {Analysis} of {Viral} and {Cellular} {MicroRNA} {Targets} in {Cells} {Latently} {Infected} with {Human} γ-{Herpesviruses} by {RISC} {Immunoprecipitation} {Assay}},
	volume = {7},
	issn = {19313128},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S1931312810001058},
	doi = {10.1016/j.chom.2010.03.008},
	abstract = {The mRNA targets of microRNAs (miRNAs) can be identiﬁed by immunoprecipitation of Argonaute (Ago) protein-containing RNA-induced silencing complexes (RISCs) followed by microarray analysis (RIP-Chip). Here we used Ago2-based RIP-Chip to identify transcripts targeted by Kaposi’s sarcomaassociated herpesvirus (KSHV) miRNAs (n = 114), Epstein-Barr virus (EBV) miRNAs (n = 44), and cellular miRNAs (n = 2337) in six latently infected or stably transduced human B cell lines. Of the six KSHV miRNA targets chosen for validation, four showed regulation via their 30UTR, while two showed regulation via binding sites within coding sequences. Two genes governing cellular transport processes (TOMM22 and IPO7) were conﬁrmed to be targeted by EBV miRNAs. A signiﬁcant number of viral miRNA targets were upregulated in infected cells, suggesting that viral miRNAs preferentially target cellular genes induced upon infection. Transcript half-life both of cellular and viral miRNA targets negatively correlated with recruitment to RISC complexes, indicating that RIP-Chip offers a quantitative estimate of miRNA function.},
	language = {en},
	number = {4},
	urldate = {2026-02-12},
	journal = {Cell Host \& Microbe},
	author = {Dölken, Lars and Malterer, Georg and Erhard, Florian and Kothe, Sheila and Friedel, Caroline C. and Suffert, Guillaume and Marcinowski, Lisa and Motsch, Natalie and Barth, Stephanie and Beitzinger, Michaela and Lieber, Diana and Bailer, Susanne M. and Hoffmann, Reinhard and Ruzsics, Zsolt and Kremmer, Elisabeth and Pfeffer, Sébastien and Zimmer, Ralf and Koszinowski, Ulrich H. and Grässer, Friedrich and Meister, Gunter and Haas, Jürgen},
	month = apr,
	year = {2010},
	pages = {324--334},
	file = {PDF:C\:\\Users\\alvarezs\\Zotero\\storage\\DKW7ZEVH\\Dölken et al. - 2010 - Systematic Analysis of Viral and Cellular MicroRNA Targets in Cells Latently Infected with Human γ-H.pdf:application/pdf},
