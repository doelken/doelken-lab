@article{gonzalez-perez_zinc_2021,
	title = {The {Zinc} {Finger} {Antiviral} {Protein} {ZAP} {Restricts} {Human} {Cytomegalovirus} and {Selectively} {Binds} and {Destabilizes} {Viral} {UL4} / {UL5} {Transcripts}},
	volume = {12},
	issn = {2150-7511},
	url = {https://journals.asm.org/doi/10.1128/mBio.02683-20},
	doi = {10.1128/mBio.02683-20},
	abstract = {Interferon-stimulated gene products (ISGs) play a crucial role in early infection control. The ISG zinc ﬁnger CCCH-type antiviral protein 1 (ZAP/ZC3HAV1) antagonizes several RNA viruses by binding to CG-rich RNA sequences, whereas its effect on DNA viruses is less well understood. Here, we decipher the role of ZAP in the context of human cytomegalovirus (HCMV) infection, a b-herpesvirus that is associated with high morbidity in immunosuppressed individuals and newborns. We show that expression of the two major isoforms of ZAP, ZAP-S and ZAP-L, is induced during HCMV infection and that both negatively affect HCMV replication. Transcriptome and proteome analyses demonstrated that the expression of ZAP results in reduced viral mRNA and protein levels and decelerates the progression of HCMV infection. Metabolic RNA labeling combined with high-throughput sequencing (SLAM-seq) revealed that most of the gene expression changes late in infection result from the general attenuation of HCMV. Furthermore, at early stages of infection, ZAP restricts HCMV by destabilizing a distinct subset of viral mRNAs, particularly those from the previously uncharacterized UL4-UL6 HCMV gene locus. Through enhanced cross-linking immunoprecipitation and sequencing analysis (eCLIP-seq), we identiﬁed the transcripts expressed from this HCMV locus as the direct targets of ZAP. Moreover, our data show that ZAP preferentially recognizes not only CG, but also other cytosinerich sequences, thereby expanding its target speciﬁcity. In summary, this report is the ﬁrst to reveal direct targets of ZAP during HCMV infection, which strongly indicates that transcripts from the UL4-UL6 locus may play an important role for HCMV replication.},
	language = {en},
	number = {3},
	urldate = {2026-02-12},
	journal = {mBio},
	author = {Gonzalez-Perez, Ana Cristina and Stempel, Markus and Wyler, Emanuel and Urban, Christian and Piras, Antonio and Hennig, Thomas and Ganskih, Sabina and Wei, Yuanjie and Heim, Albert and Landthaler, Markus and Pichlmair, Andreas and Dölken, Lars and Munschauer, Mathias and Erhard, Florian and Brinkmann, Melanie M.},
	editor = {Horner, Stacy M.},
	month = jun,
	year = {2021},
	pages = {e02683--20},
	file = {PDF:C\:\\Users\\alvarezs\\Zotero\\storage\\FB8T2D7C\\Gonzalez-Perez et al. - 2021 - The Zinc Finger Antiviral Protein ZAP Restricts Human Cytomegalovirus and Selectively Binds and Dest.pdf:application/pdf},
}

