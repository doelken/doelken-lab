	author = {Knies, Kerstin and Wagenhäuser, Isabell and Hofmann, Daniela and Rauschenberger, Vera and Eisenmann, Michael and Reusch, Julia and Flemming, Sven and Andres, Oliver and Petri, Nils and Topp, Max S. and Papsdorf, Michael and McDonogh, Miriam and Verma-Führing, Raoul and Scherzad, Agmal and Zeller, Daniel and Böhm, Hartmut and Gesierich, Anja and Seitz, Anna Katharina and Kiderlen, Michael and Gawlik, Micha and Taurines, Regina and Wurmb, Thomas and Ernestus, Ralf-Ingo and Forster, Johannes and Weismann, Dirk and Weißbrich, Benedikt and Liese, Johannes and Vogel, Ulrich and Kurzai, Oliver and Dölken, Lars and Gabel, Alexander and Krone, Manuel},
