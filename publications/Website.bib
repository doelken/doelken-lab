	url = {https://dx.plos.org/10.1371/journal.pone.0242917},
	doi = {10.1371/journal.pone.0242917},
	abstract = {Background The viral load and tissue distribution of severe acute respiratory syndrome coronavirus 2 (SARS-CoV-2) remain important questions. The current study investigated SARS-CoV-2 viral load, biodistribution and anti-SARS-CoV-2 antibody formation in patients suffering from severe corona virus disease 2019 (COVID-19) induced acute respiratory distress syndrome (ARDS).},
