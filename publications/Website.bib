	file = {PDF:C\:\\Users\\alvarezs\\Zotero\\storage\\URSXFIHL\\Tomac et al. - 2021 - Viral infection of the ovaries compromises pregnancy and reveals innate immune mechanisms protecting.pdf:application/pdf},
